ENVIRONMENT=dev
HTTP_PORT=8000
ADMIN_SECRET_KEY=changeme
LOG_LEVEL=INFO

# Gateway 连接
GATEWAY_BASE_URL=https://llm.clawdy.dev
GATEWAY_BIZ_KEY=your-biz-secret-key

# E2B
E2B_API_KEY=your-e2b-api-key
E2B_TEMPLATE_ID=base
E2B_SANDBOX_TIMEOUT=86400
E2B_SANDBOX_PORT=3000

# S3
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=openclaw-manager
S3_PREFIX=dev/

# BlueBubbles webhook
BLUEBUBBLES_PASSWORD=
FORWARD_TIMEOUT_MS=10000
UNKNOWN_SENDER_CALLBACK_URL=

# 续期
RENEWAL_INTERVAL_HOURS=24
RENEWAL_CHECK_MINUTES=5
